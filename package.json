{
  "name": "@kpolley/redai",
  "version": "0.1.2",
  "description": "Terminal workbench for AI-assisted vulnerability discovery and validation.",
  "type": "module",
  "bin": {
    "redai": "./src/tui/main.tsx"
  },
  "scripts": {
    "redai": "bun run src/tui/main.tsx",
    "dev": "bun run src/tui/main.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check src",
    "prepublishOnly": "bun run typecheck && bun run lint"
  },
  "files": [
    "src",
    "!src/tui/README.md",
    "!src/validators/AGENTS.md",
    "vendor/tree-sitter",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kpolley/redai.git"
  },
  "bugs": {
    "url": "https://github.com/kpolley/redai/issues"
  },
  "homepage": "https://github.com/kpolley/redai#readme",
  "keywords": [
    "security",
    "vulnerability-scanning",
    "ai",
    "tui",
    "codex",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@anthropic-ai/sdk": "^0.85.0",
    "@inkjs/ui": "^2.0.0",
    "@openai/codex-sdk": "^0.118.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "ink": "^6.8.0",
    "marked": "^18.0.0",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "web-tree-sitter": "^0.26.8",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "tree-sitter-cli": "^0.26.8",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "^6.0.2"
  }
}
